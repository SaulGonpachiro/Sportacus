<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!-- Conexión a MariaDB/MySQL -->
        <property name="hibernate.connection.driver_class">org.mariadb.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mariadb://localhost:3306/sportacus</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password"></property>

        <!-- Dialecto -->
        <property name="hibernate.dialect">org.hibernate.dialect.MariaDB103Dialect</property>

        <!-- Opciones útiles en desarrollo -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <property name="hibernate.hbm2ddl.auto">none</property>

        <!-- Entidades -->
        <mapping class="org.example.sportacus.model.Usuario"/>
        <mapping class="org.example.sportacus.model.Deporte"/>
        <mapping class="org.example.sportacus.model.Instalacion"/>
        <mapping class="org.example.sportacus.model.Pista"/>
        <mapping class="org.example.sportacus.model.Reserva"/>
        <mapping class="org.example.sportacus.model.BloqueoPista"/>
    </session-factory>
</hibernate-configuration>
