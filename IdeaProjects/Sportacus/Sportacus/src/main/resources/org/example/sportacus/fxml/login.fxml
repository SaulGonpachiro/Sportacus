<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane stylesheets="@../css/login.css" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.sportacus.controller.LoginController">

    <children>

        <!-- FONDO -->
        <ImageView fitHeight="1200" fitWidth="2000" preserveRatio="false">
            <image>
                <Image url="@../images/fondo.png" />
            </image>
        </ImageView>

        <!-- CONTENIDO -->
        <VBox alignment="CENTER" spacing="40">

            <!-- LOGO COMPLETO -->
            <ImageView fitHeight="180" preserveRatio="true">
                <image>
                    <Image url="@../images/logo_completo.png" />
                </image>
                <VBox.margin>
                    <Insets left="100.0" />
                </VBox.margin>
            </ImageView>

            <!-- Tarjeta -->
            <VBox alignment="CENTER" maxWidth="450" spacing="25" styleClass="login-card">

                <Label styleClass="title-label" text="Iniciar Sesión" />

                <TextField fx:id="emailField" promptText="Correo electrónico" styleClass="input-field" />

                <PasswordField fx:id="passwordField" promptText="Contraseña" styleClass="input-field" />

                <Button maxWidth="Infinity" onAction="#handleLogin" styleClass="primary-button" text="Iniciar Sesión" />

                <Button maxWidth="Infinity" onAction="#handleRegistro" styleClass="secondary-button" text="Registrarse" />

            </VBox>

        </VBox>

    </children>

</StackPane>
